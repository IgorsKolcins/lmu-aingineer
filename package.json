{
  "name": "aingineer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "main.ts",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "predev": "bun run rebuild:native",
    "dev": "bun run ./scripts/Dev.ts",
    "build:electron": "bun build ./main.ts --outfile ./dist-electron/main.js --target=node --format=esm --external electron --external better-sqlite3 && bun build ./preload.cjs --outfile ./dist-electron/preload.cjs --target=node --format=cjs --external electron",
    "build": "vite build",
    "build:app": "bun run build && bun run build:electron",
    "prestart": "bun run build:app",
    "start": "electron ./dist-electron/main.js",
    "dist:win:portable": "bun run build:app && electron-builder --win portable --x64",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "check": "tsc --noEmit && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@tanstack/router-plugin": "^1.166.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@fontsource-variable/raleway": "^5.2.8",
    "@google/genai": "^1.45.0",
    "@monaco-editor/react": "^4.7.0",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.8",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "monaco-editor": "^0.55.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.lmu.aingineer",
    "productName": "LMU AIngineer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-portable.${ext}",
      "executableName": "LMU AIngineer"
    }
  }
}
